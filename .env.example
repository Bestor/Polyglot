# Required: powers cmd/valorantapi's HenrikDev ingest client. Unlike
# before the two-binary split, this is not optional and not a
# polyglot-onboarding convenience - valorantapi is a single-domain
# service, so this is just its own boot-time config, the same way
# DISCORD_BOT_TOKEN/ANTHROPIC_API_KEY are cmd/discordbot's.
HENRIK_API_KEY=
HENRIK_BASE_URL=https://api.henrikdev.xyz
HENRIK_RATE_LIMIT_PER_MINUTE=30

API_AUTH_TOKEN=

# Optional: if set, cmd/polyglot auto-onboards cmd/valorantapi as a
# "valorant" http_sql datasource on boot (see autoOnboardValorantAPIFromEnv
# in cmd/polyglot/main.go) - a convenience wrapper around the same config
# any http_sql datasource can be onboarded with at runtime via
# POST /datasources. docker-compose.yml sets these directly in the
# polyglot service's environment (http://valorantapi:8093 + API_AUTH_TOKEN)
# rather than through this file - only needed here when running polyglot
# directly, outside Compose. Leave unset to boot with zero datasources
# onboarded and onboard everything via the API instead.
VALORANT_API_URL=
VALORANT_API_AUTH_TOKEN=

# Required: cmd/polyglot's OpenBao (self-hosted Vault fork) client - every
# onboarded datasource's secrets (e.g. an http_sql datasource's
# auth_token) live there, never as plaintext in polyglot's own persisted
# config. VAULT_UNSEAL_KEY is required, not just VAULT_ADDR/VAULT_TOKEN,
# because OpenBao's file storage backend starts sealed on every real
# restart and this project auto-unseals on boot rather than requiring a
# manual `bao operator unseal` step each time - see internal/vault. In
# production this whole init/policy dance is fully automated by
# terraform/bootstrap-vault.sh (no by-hand setup, no GitHub secrets for
# these two values) - locally, without that script, you still need to run
# the one-time `bao operator init`/policy setup yourself; see
# terraform/README.md's "OpenBao setup and operations" section for the
# exact commands.
# docker-compose.yml points VAULT_ADDR at the openbao service automatically.
VAULT_ADDR=http://localhost:8200
VAULT_TOKEN=
VAULT_UNSEAL_KEY=

# Optional: auto-provisions the PocketBase admin UI superuser on boot
# instead of requiring a manual first-run setup step. Set both or neither.
# Applies to both cmd/polyglot and cmd/valorantapi (each has its own
# PocketBase, so each provisions its own superuser from these same values).
SUPERUSER_EMAIL=
SUPERUSER_PASSWORD=

PORT=8090
PB_DATA_DIR=pb_data
# Note: docker-compose.yml overrides PORT to 8091 for polyglot, 8092 for
# mcpserver, and 8093 for valorantapi - the values here only apply when
# running a binary directly (outside `docker compose up`).

# Optional: overrides valorantapi's pb_data volume source in
# docker-compose.yml from the default named volume to a host path - only
# meant to be set in production (via terraform/cloud-init.yaml.tftpl,
# pointing at the mounted DigitalOcean Volume from terraform/volume.tf) so
# the cache survives a droplet recreate. Leave unset for local dev. Named
# PB_DATA_HOST_PATH (not VALORANTAPI_DATA_HOST_PATH) because it's the same
# variable/mount path the pre-split single polyglot binary used to use -
# unchanged so the droplet's existing cached match data carries over.
PB_DATA_HOST_PATH=
# Same idea, for polyglot's own (separate, smaller) onboarding/catalog
# bookkeeping database - always starts fresh, no cutover concern.
PB_METADATA_HOST_PATH=
# Same idea, for OpenBao's file storage backend.
VAULT_DATA_HOST_PATH=

# Verbose slog output (cmd/polyglot, cmd/valorantapi, cmd/mcpserver): full
# SQL query text, /warm and MCP tool-call arguments, and MCP response
# bodies. Off by default since those can be large; concise one-line logs
# (endpoint/tool name, status, duration) are always on regardless of this
# setting.
DEBUG=false

# --- cmd/mcpserver only (a separate binary/process) ---
# mcpserver reads its own PORT (default 8092, distinct from the PORT above
# which is cmd/polyglot's listen port) - set it explicitly via -e/--env
# when running mcpserver alongside polyglot, don't rely on this file's
# single PORT= value for it.
#
# Base URL of a running cmd/polyglot instance to proxy MCP tool calls to.
# docker-compose.yml overrides this to http://polyglot:8091 (the in-network
# service hostname) for the containerized flow - the localhost value below
# only applies when running mcpserver directly, outside Compose.
POLYGLOT_URL=http://localhost:8091
# Must match polyglot's own API_AUTH_TOKEN (i.e. API_AUTH_TOKEN above).
POLYGLOT_AUTH_TOKEN=
# Path to the OpenAPI spec mcpserver derives its tools from. Defaults to
# openapi/polyglot.yaml if unset.
OPENAPI_SPEC_PATH=openapi/polyglot.yaml

# --- cmd/cachewarmer only ---
# Confusingly named POLYGLOT_URL/POLYGLOT_AUTH_TOKEN for historical
# reasons (unchanged since before the two-binary split) - actually points
# at cmd/valorantapi now, the only service left with a /warm endpoint.
# docker-compose.yml overrides these to http://valorantapi:8093 + the
# API_AUTH_TOKEN value for the containerized flow.
#
# Path to the newline-delimited player list (one Riot ID as name#tag per
# line, e.g. OrBest#NA1; blank lines and lines starting with # are
# ignored). Defaults to cmd/cachewarmer/players.txt, correct for running
# the binary directly from the repo root - docker-compose.yml overrides
# this to /app/players.txt for the containerized flow, matching where it
# bind-mounts cmd/cachewarmer/players.txt to in that container, so edits
# to the repo file take effect on the next pass without a rebuild/restart.
PLAYERS_FILE=cmd/cachewarmer/players.txt
# function passed to each POST /warm call (valorantapi hosts exactly one
# domain, so no datasource field is needed here anymore).
WARM_FUNCTION=sync_matches
# How often to re-run the full player list, as a Go duration (e.g. 30m, 1h, 2h).
WARM_INTERVAL=1h

# --- cmd/discordbot only (optional - the discordbot Compose service only
# starts when the "discordbot" profile below is active) ---
# Uncomment once DISCORD_BOT_TOKEN and ANTHROPIC_API_KEY are set, to make
# `docker compose up` (via run.sh) also start the discordbot service.
# COMPOSE_PROFILES=discordbot
# Discord bot token (Discord Developer Portal -> your application -> Bot).
DISCORD_BOT_TOKEN=
# Anthropic API key for the tool-use loop that decides which MCP tools to call.
ANTHROPIC_API_KEY=
# Optional: defaults to claude-opus-4-8 if unset. Only override if you
# specifically want a different model (e.g. a cheaper/faster one) - that's
# a deliberate choice, not something the bot picks for you.
ANTHROPIC_MODEL=
# Optional: register the /ask slash command to one guild for instant
# availability during development, instead of registering it globally
# (which can take up to ~1hr to propagate to Discord clients).
DISCORD_GUILD_ID=
