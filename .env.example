HENRIK_API_KEY=
HENRIK_BASE_URL=https://api.henrikdev.xyz
HENRIK_RATE_LIMIT_PER_MINUTE=30

API_AUTH_TOKEN=

# Optional: auto-provisions the PocketBase admin UI superuser on boot
# instead of requiring a manual first-run setup step. Set both or neither.
SUPERUSER_EMAIL=
SUPERUSER_PASSWORD=

PORT=8090
PB_DATA_DIR=pb_data

AI_PROVIDER=mock
# AI_PROVIDER=claude
ANTHROPIC_API_KEY=

# Verbose slog output (cmd/server, cmd/polyglot, cmd/mcpserver): full SQL
# query text, /warm and MCP tool-call arguments, and MCP response bodies.
# Off by default since those can be large; concise one-line logs (endpoint/
# tool name, status, duration) are always on regardless of this setting.
DEBUG=false

# --- cmd/mcpserver only (a separate binary/process from cmd/server/cmd/polyglot) ---
# mcpserver reads its own PORT (default 8092, distinct from the PORT above
# which is cmd/server/cmd/polyglot's listen port) - set it explicitly via
# -e/--env when running mcpserver alongside the others, don't rely on this
# file's single PORT= value for it.
#
# Base URL of a running cmd/polyglot instance to proxy MCP tool calls to.
POLYGLOT_URL=http://localhost:8091
# Must match polyglot's own API_AUTH_TOKEN (i.e. API_AUTH_TOKEN above).
POLYGLOT_AUTH_TOKEN=
# Path to the OpenAPI spec mcpserver derives its tools from. Defaults to
# openapi/polyglot.yaml if unset.
OPENAPI_SPEC_PATH=openapi/polyglot.yaml
